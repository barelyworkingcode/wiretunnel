# WireGuard configs contain private keys — never commit them.
# Templates ending in .example.conf are the exception.
*.conf
!*.example.conf

# DPAPI-sealed configs are host-bound ciphertext, but still host-specific and
# not meant for the repo.
*.dpapi

# Compiled binaries — build into ./bin/ (ignored). Also catch stray root builds.
/bin/
/wiretunnel
*.exe

# Go test/coverage output
*.test
*.out
coverage.*

# webssh TLS material and passkey store. These normally live in the OS config
# dir (<UserConfigDir>/wiretunnel/), but guard against in-tree generation.
*.pem
store.json

# OS / editor cruft
.DS_Store
*.swp
